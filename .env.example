# Backend server
PORT=8787

# GitHub Personal Access Token (PAT)
# Used for:
# - GitHub REST API calls (repo/profile fetching)
# - GitHub Models (OpenAI-compatible) calls at https://models.inference.ai.azure.com
# Create a PAT that also has GitHub Models access (the "models" permission),
# otherwise AI calls will fail with: "401 The `models` permission is required".
# Get your token at: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=github_pat_YOUR_TOKEN_HERE